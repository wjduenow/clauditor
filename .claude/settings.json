{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          },
          {
            "command": "echo '\\n## Maintainer skills\\n' && for f in .claude/skills/*/SKILL.md; do name=$(grep -m1 '^name:' \"$f\" | sed 's/^name: *//'); desc=$(grep -m1 '^description:' \"$f\" | sed 's/^description: *//' | awk '{if(length>90){s=substr($0,1,90); sub(/ [^ ]*$/,\"\",s); print s\"…\"}else print}'); echo \"  /$name  —  $desc\"; done && echo ''",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "allowedTools": {
    "allow": [
      "Bash(git:*)",
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(alembic:*)",
      "Bash(bd:*)",
      "Bash(gh:*)",
      "Bash(cd:*)",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(rm:*)",
      "Bash(cat:*)",
      "Bash(sleep:*)",
      "Bash(date:*)",
      "Bash(echo:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(chmod:*)",
      "Bash(tmux:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch"
    ]
  }
}
