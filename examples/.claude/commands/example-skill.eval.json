{
  "skill_name": "find-kid-activities",
  "description": "Validates /find-kid-activities produces venues and events with required fields",
  "test_args": "\"Cupertino, CA\" --dates today --distance 15mi --ages 4-6 --cost \"Free, $\" --type both --category any --count 5 --depth quick",
  "input_files": [
    "sample-input.txt"
  ],
  "assertions": [
    {
      "type": "contains",
      "value": "Venues",
      "id": "contains_venues"
    },
    {
      "type": "contains",
      "value": "Events",
      "id": "contains_events"
    },
    {
      "type": "has_entries",
      "value": "3",
      "id": "has_entries_3"
    },
    {
      "type": "has_urls",
      "value": "3",
      "id": "has_urls_3"
    },
    {
      "type": "min_length",
      "value": "500",
      "id": "min_length_500"
    },
    {
      "type": "not_contains",
      "value": "AskUserQuestion",
      "id": "no_ask_user_question"
    },
    {
      "type": "regex",
      "value": "\\*\\*\\d+\\.\\s+",
      "id": "regex_numbered_bold"
    },
    {
      "type": "regex",
      "value": "https?://[^\\s]+",
      "id": "regex_url"
    }
  ],
  "sections": [
    {
      "name": "Venues",
      "tiers": [
        {
          "label": "default",
          "min_entries": 2,
          "fields": [
            {
              "name": "name",
              "required": true,
              "id": "venue_name"
            },
            {
              "name": "address",
              "required": true,
              "id": "venue_address"
            },
            {
              "name": "hours",
              "required": true,
              "id": "venue_hours"
            },
            {
              "name": "website",
              "required": true,
              "id": "venue_website"
            },
            {
              "name": "phone",
              "required": false,
              "id": "venue_phone"
            },
            {
              "name": "cost",
              "required": true,
              "id": "venue_cost"
            },
            {
              "name": "ages",
              "required": true,
              "id": "venue_ages"
            }
          ]
        }
      ]
    },
    {
      "name": "Events",
      "tiers": [
        {
          "label": "default",
          "min_entries": 0,
          "fields": [
            {
              "name": "name",
              "required": true,
              "id": "event_name"
            },
            {
              "name": "date",
              "required": true,
              "id": "event_date"
            },
            {
              "name": "time",
              "required": true,
              "id": "event_time"
            },
            {
              "name": "event_url",
              "required": true,
              "id": "event_event_url"
            },
            {
              "name": "ages",
              "required": true,
              "id": "event_ages"
            }
          ]
        }
      ]
    }
  ],
  "grading_criteria": [
    {
      "id": "distance_match",
      "criterion": "Are all venues within the specified distance?"
    },
    {
      "id": "age_appropriate",
      "criterion": "Are venues appropriate for the specified age range?"
    },
    {
      "id": "events_on_target_date",
      "criterion": "Are events actually happening on the target date?"
    },
    {
      "id": "cost_tier_match",
      "criterion": "Do cost tiers match the specified budget filter?"
    }
  ],
  "grading_model": "claude-sonnet-4-6",
  "trigger_tests": {
    "should_trigger": [
      "Find kid activities in Cupertino",
      "What are some things to do with kids near me?"
    ],
    "should_not_trigger": [
      "What's the weather today?",
      "Help me write a Python script"
    ]
  },
  "variance": {
    "n_runs": 5,
    "min_stability": 0.8
  }
}
